# Copy this file to .env for local testing.
# Do not commit your real .env file.
#
# In Upstash Console, open your Redis database, then copy:
# Endpoint -> UPSTASH_REDIS_HOST
# Port -> UPSTASH_REDIS_PORT
# Password/Token -> UPSTASH_REDIS_PASSWORD

UPSTASH_REDIS_HOST=your-upstash-endpoint.upstash.io
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=your-upstash-password
